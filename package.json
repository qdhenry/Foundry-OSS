{
  "name": "foundry-app",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "sandbox-worker",
    "agent-service",
    "agent-worker"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun --env-file=.env.local run --cwd apps/web dev",
    "dev:agent": "bun --cwd agent-service run dev",
    "dev:agent-worker": "bun --cwd agent-worker run dev",
    "dev:worker": "bun --cwd sandbox-worker run dev:local",
    "dev:worker:remote": "bun --cwd sandbox-worker run dev:remote",
    "dev:convex": "bunx convex dev",
    "dev:docs": "bun run --cwd apps/docs dev",
    "dev:zellij": "bash ./scripts/zellij-dev.sh",
    "run:desktop:debug-prod": "RUST_LOG=debug RUST_BACKTRACE=1 \"./apps/desktop/src-tauri/target/debug/bundle/macos/Foundry Desktop.app/Contents/MacOS/foundry_desktop_tauri\"",
    "debug:desktop:prod": "bun run build:desktop:debug && bun run run:desktop:debug-prod",
    "build": "bun run --cwd apps/web build",
    "build:docs": "bun run --cwd apps/docs build",
    "start": "bun run --cwd apps/web start",
    "test": "vitest run",
    "test:coverage:web": "node scripts/apps-web-coverage.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "bun run typecheck:web && bun run typecheck:convex && bun run typecheck:agent && bun run typecheck:worker && bun run typecheck:agent-worker && bun run typecheck:docs",
    "verify:push": "bun run check && bun run typecheck",
    "verify:ci": "bun run check && bun run typecheck && bun run test",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:convex": "tsc --noEmit -p convex/tsconfig.json",
    "typecheck:agent": "tsc --noEmit -p agent-service/tsconfig.json",
    "typecheck:worker": "tsc --noEmit -p sandbox-worker/tsconfig.json",
    "typecheck:agent-worker": "tsc --noEmit -p agent-worker/tsconfig.json",
    "typecheck:docs": "bun run --cwd apps/docs check",
    "watch:files": "node scripts/watch-files.mjs",
    "build:desktop": "bun run --cwd apps/desktop tauri build",
    "build:desktop:debug": "bun run --cwd apps/desktop tauri build --debug",
    "reel": "WEBREEL_BROWSER_PORT=9222 webreel record",
    "reel:preview": "WEBREEL_BROWSER_PORT=9222 webreel preview",
    "reel:watch": "WEBREEL_BROWSER_PORT=9222 webreel record --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@clerk/clerk-react": "^5.60.0",
    "@clerk/nextjs": "^6.37.3",
    "@convex-dev/workflow": "0.3.9",
    "@convex-dev/workpool": "0.4.6",
    "@gsap/react": "^2.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@uiw/react-codemirror": "^4.24.0",
    "@untitledui/icons": "^0.0.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "convex": "^1.31.7",
    "convex-helpers": "0.1.113",
    "express": "^5.2.1",
    "fuse.js": "^7.1.0",
    "gsap": "^3.14.2",
    "handlebars": "^4.7.8",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-aria-components": "^1.15.0",
    "react-dom": "19.2.3",
    "stripe": "^21.0.1",
    "svix": "^1.84.1",
    "tailwind-merge": "^3.4.0",
    "twelvelabs-js": "^1.2.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@chromatic-com/storybook": "^5.0.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/nextjs-vite": "^10.2.10",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "agent-tail": "^0.3.4",
    "chokidar": "^5.0.0",
    "convex-test": "^0.0.41",
    "jsdom": "^28.0.0",
    "lefthook": "^2.1.4",
    "playwright": "^1.58.2",
    "storybook": "^10.2.10",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "webreel": "^0.1.4"
  },
  "patchedDependencies": {
    "webreel@0.1.4": "patches/webreel@0.1.4.patch"
  }
}
