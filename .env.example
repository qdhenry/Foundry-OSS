# =============================================================================
# Root .env.example — Next.js + Convex + Integrations
# =============================================================================
# Copy to .env.local and fill in values:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Convex
# -----------------------------------------------------------------------------
# Convex deployment URL (from `npx convex dev` output)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex deployment identifier (set automatically by `npx convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment

# Convex HTTP actions site URL (for webhook endpoints)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWT_ISSUER_DOMAIN=https://your-domain.clerk.accounts.dev

# Clerk webhook secret for user sync (from Clerk Dashboard → Webhooks)
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# -----------------------------------------------------------------------------
# GitHub App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_ID=0000000
GITHUB_APP_CLIENT_ID=your_github_app_client_id
GITHUB_APP_CLIENT_SECRET=your_github_app_client_secret

# RSA private key (newlines escaped as \n)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----"

# HMAC secret for GitHub webhook signature validation
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# -----------------------------------------------------------------------------
# Sandbox Worker
# -----------------------------------------------------------------------------
# URL of the Cloudflare sandbox worker
# Local dev: http://127.0.0.1:8788
# Production: https://migration-sandbox-worker.<account>.workers.dev
SANDBOX_WORKER_URL=http://127.0.0.1:8788

# Shared secret between Convex and sandbox worker for API auth + hook events
# Generate with: openssl rand -hex 32
# IMPORTANT: Must match SANDBOX_API_SECRET in sandbox-worker/.dev.vars
SANDBOX_API_SECRET=your_sandbox_api_secret

# -----------------------------------------------------------------------------
# Anthropic (AI)
# -----------------------------------------------------------------------------
# API key for Claude AI (set in Convex dashboard for production)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# -----------------------------------------------------------------------------
# Auth Provider
# -----------------------------------------------------------------------------
# "clerk" (default, multi-tenant) or "simple" (single-tenant, no external deps)
# FOUNDRY_AUTH_PROVIDER=clerk

# Simple auth settings (only used when FOUNDRY_AUTH_PROVIDER=simple)
# FOUNDRY_ADMIN_EMAIL=admin@example.com
# FOUNDRY_ADMIN_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------------
# Agent Service
# -----------------------------------------------------------------------------
AGENT_SERVICE_URL=http://localhost:3001

# Bearer token for agent worker auth (production only, not needed for local dev)
# Generate with: openssl rand -hex 32
# AGENT_SERVICE_SECRET=your_agent_service_secret

# -----------------------------------------------------------------------------
# Atlassian (Jira + Confluence) — Optional
# -----------------------------------------------------------------------------
ATLASSIAN_CLIENT_ID=your_atlassian_client_id
ATLASSIAN_CLIENT_SECRET=your_atlassian_client_secret
ATLASSIAN_OAUTH_REDIRECT_URI=http://localhost:3000/api/atlassian/callback

# HMAC secret for Jira/Confluence webhook signature validation
# Generate with: openssl rand -hex 32
# NOTE: Must also be set in Convex dashboard environment variables
ATLASSIAN_WEBHOOK_SECRET=your_atlassian_webhook_secret

# AES-256 encryption key for Atlassian OAuth token storage
# Must be exactly 32 bytes, base64-encoded
# Generate with: openssl rand -base64 32
# NOTE: Must also be set in Convex dashboard environment variables
ATLASSIAN_TOKEN_ENCRYPTION_KEY=your_base64_encryption_key

# -----------------------------------------------------------------------------
# AI / Media Services — Optional
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key
TWELVELABS_API_KEY=your_twelvelabs_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# -----------------------------------------------------------------------------
# Stripe Billing — Optional (Enterprise)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# -----------------------------------------------------------------------------
# Google Drive — Optional
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
