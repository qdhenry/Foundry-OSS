{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "description": "Default capability set for the Foundry Desktop main window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "deep-link:default",
    "shell:default",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "foundry_shell_zsh",
          "cmd": "/bin/zsh",
          "args": true
        },
        {
          "name": "foundry_shell_bash",
          "cmd": "/bin/bash",
          "args": true
        },
        {
          "name": "foundry_shell_sh",
          "cmd": "/bin/sh",
          "args": true
        },
        {
          "name": "foundry_shell_pwsh",
          "cmd": "pwsh",
          "args": true
        },
        {
          "name": "foundry_shell_powershell",
          "cmd": "powershell.exe",
          "args": true
        },
        {
          "name": "foundry_shell_cmd",
          "cmd": "cmd.exe",
          "args": true
        },
        {
          "name": "zsh",
          "cmd": "/bin/zsh",
          "args": true
        },
        {
          "name": "bash",
          "cmd": "/bin/bash",
          "args": true
        },
        {
          "name": "sh",
          "cmd": "/bin/sh",
          "args": true
        },
        {
          "name": "pwsh",
          "cmd": "pwsh",
          "args": true
        },
        {
          "name": "powershell",
          "cmd": "powershell.exe",
          "args": true
        },
        {
          "name": "cmd",
          "cmd": "cmd.exe",
          "args": true
        }
      ]
    }
  ]
}
