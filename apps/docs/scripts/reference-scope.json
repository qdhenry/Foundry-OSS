{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Reference surface whitelist for Foundry self-hosting docs. ~60 public functions a self-hoster would most likely need.",
  "tables": [
    "programs",
    "workstreams",
    "requirements",
    "skills",
    "skillVersions",
    "risks",
    "sprintGates",
    "agentExecutions",
    "users",
    "teamMembers",
    "auditLog",
    "sprints",
    "tasks",
    "subtasks",
    "integrations",
    "documents",
    "discoveryFindings",
    "documentAnalyses",
    "playbooks",
    "playbookInstances",
    "comments",
    "evidence",
    "notifications",
    "workstreamDependencies",
    "sandboxSessions",
    "sandboxConfigs",
    "sandboxPresets",
    "sandboxQueue",
    "sandboxLogs",
    "envVault",
    "sourceControlInstallations",
    "sourceControlRepositories",
    "sourceControlPullRequests",
    "sourceControlCommits",
    "sourceControlDeployments",
    "atlassianConnections",
    "jiraSyncRecords",
    "confluencePageRecords",
    "videoAnalyses",
    "videoFindings",
    "designAssets",
    "designTokenSets",
    "subscriptions",
    "pricingPlans",
    "trialState",
    "aiUsageRecords",
    "serviceHealthChecks",
    "serviceIncidents",
    "orchestrationRuns",
    "programAgents",
    "agentTemplates",
    "sprintWorkflows"
  ],
  "functions": {
    "programs": [
      "list",
      "get",
      "create",
      "update",
      "updatePhase",
      "getStats",
      "remove",
      "getBySlug",
      "getNavigationState",
      "suggestWorkstreams"
    ],
    "workstreams": ["listByProgram", "get", "update"],
    "requirements": [
      "listByProgram",
      "get",
      "create",
      "update",
      "updateStatus",
      "countByStatus",
      "countByPriority",
      "listAllByProgram",
      "listWithPipelineContext",
      "pipelineStageCounts",
      "bulkAssignWorkstream",
      "remove"
    ],
    "skills": [
      "listByProgram",
      "get",
      "create",
      "update",
      "updateContent",
      "linkRequirement",
      "unlinkRequirement",
      "listTemplates",
      "forkTemplate"
    ],
    "skillVersions": ["listBySkill", "get", "compare"],
    "risks": ["listByProgram", "get", "create", "update", "updateStatus", "remove"],
    "tasks": [
      "listByProgram",
      "get",
      "create",
      "update",
      "updateStatus",
      "remove",
      "countBySprint",
      "listUnassignedByWorkstream",
      "bulkAssignToSprint"
    ],
    "subtasks": ["listByTask", "get", "create", "update", "updateStatus", "reorder", "remove"],
    "sprints": [
      "listByProgram",
      "listByWorkstream",
      "get",
      "create",
      "update",
      "activate",
      "complete",
      "getActive",
      "remove"
    ],
    "sprintGates": [
      "listByProgram",
      "listByWorkstream",
      "get",
      "create",
      "evaluateCriterion",
      "addApproval",
      "finalize",
      "remove"
    ],
    "agentExecutions": [
      "listByProgram",
      "get",
      "getDetail",
      "listRecent",
      "listByTask",
      "updateReview"
    ],
    "users": ["getByClerkId", "list", "syncActiveOrg"],
    "teamMembers": ["listByProgram", "add", "update", "remove"],
    "auditLog": ["listByProgram", "listByEntity"],
    "notifications": ["listUnread", "listRecent", "markRead", "markAllRead"],
    "documents": ["generateUploadUrl", "save", "listByProgram", "get", "update", "remove"],
    "comments": ["listByEntity", "create", "remove"],
    "evidence": ["generateUploadUrl", "save", "listByRequirement", "remove"],
    "discoveryFindings": [
      "listByProgram",
      "listByDocument",
      "countPending",
      "reviewFinding",
      "bulkReviewFindings",
      "importApprovedFindings"
    ],
    "integrations": ["listByProgram", "get", "create", "update", "remove"],
    "playbooks": ["listByProgram", "get", "create", "update", "publish", "remove", "instantiate"],
    "search": ["globalSearch"],
    "sandbox/sessions": [
      "get",
      "getByTask",
      "listByProgram",
      "listByOrg",
      "cancel",
      "getChatMessages",
      "sendChatMessage",
      "deleteSession"
    ],
    "sandbox/orchestrator": [
      "start",
      "startLocal",
      "stop",
      "wake",
      "shutdown",
      "startSubtaskExecution",
      "continueAfterPause",
      "retryFailedSubtask"
    ],
    "sandbox/configs": ["getByOrg", "upsert", "remove"],
    "sandbox/presets": ["listForOrg", "get", "upsert", "remove"],
    "sandbox/envVault": ["listByOrg", "get", "upsert", "remove"],
    "sandbox/logs": ["listBySession", "listByTask"],
    "sourceControl/repositories": [
      "connectRepository",
      "disconnectRepository",
      "listByProgram",
      "getInstallation"
    ],
    "sourceControl/installations": ["listByOrg", "claimInstallation"],
    "atlassian/connections": [
      "getByProgram",
      "listByOrg",
      "startOAuth",
      "completeOAuth",
      "updateBindings",
      "disconnect"
    ],
    "orchestration/runs": ["get", "listByProgram", "listActive", "create", "updateStatus"],
    "orchestration/planner": ["generatePlan", "estimateCost"],
    "billing/subscriptions": ["getOrgSubscription", "getOrgBillingState"],
    "billing/plans": ["getPricingPlans", "getPlanBySlug"],
    "billing/trial": ["getTrialState", "getTrialStatus", "initializeTrial"],
    "billing/analytics": ["getOrgCostSummary", "getOrgCostTimeline"],
    "health/serviceHealth": ["getLatestHealthByService", "getActiveIncidents", "recordHealthCheck"]
  }
}
