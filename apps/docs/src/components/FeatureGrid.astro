---
/**
 * FeatureGrid — home-page feature grid for Foundry docs.
 *
 * Pure Astro component (no React). Rendered below the Hero on the home
 * page. Each card links into one of the four top-level IA groups plus
 * the headline flagship surfaces (Sandbox, Mission Control).
 *
 * Icons are inlined SVG strings so we don't depend on @foundry/ui
 * React components.
 */

interface Feature {
  title: string;
  description: string;
  href: string;
  icon: "compass" | "layers" | "bolt" | "terminal" | "shield" | "book";
}

const features: Feature[] = [
  {
    title: "Getting Started",
    description:
      "Prerequisites, quickstart, and your first Foundry program running against AcmeCorp seed data.",
    href: "/getting-started/",
    icon: "compass",
  },
  {
    title: "Architecture & Concepts",
    description:
      "Programs, workstreams, requirements, skills, sandboxes — and how the four-process distributed system fits together.",
    href: "/architecture/",
    icon: "layers",
  },
  {
    title: "Deployment & Operations",
    description:
      "Production setup on Vercel + Convex Cloud + Cloudflare, cost estimates, and rollback procedures.",
    href: "/deployment/",
    icon: "shield",
  },
  {
    title: "Features Walkthroughs",
    description:
      "Step-by-step tours of every user-facing surface: tasks, discovery, pipeline lab, skills, risks, gates, billing.",
    href: "/features/",
    icon: "bolt",
  },
  {
    title: "Sandbox Execution",
    description:
      "Provision ephemeral Claude Code environments, watch real-time logs, and autocommit your way to a PR.",
    href: "/features/sandbox/",
    icon: "terminal",
  },
  {
    title: "Reference",
    description:
      "Auto-generated schema and function reference, plus hand-written CLI and environment variable deep dives.",
    href: "/reference/",
    icon: "book",
  },
];

const icons: Record<Feature["icon"], string> = {
  compass: `<circle cx="12" cy="12" r="9" /><path d="M15.5 8.5 13 13l-4.5 2.5L11 11z" />`,
  layers: `<path d="m12 3 9 4.5L12 12 3 7.5z" /><path d="m3 12 9 4.5L21 12" /><path d="m3 16.5 9 4.5 9-4.5" />`,
  bolt: `<path d="M13 2 4.5 13H12l-1 9 8.5-11H13z" />`,
  terminal: `<rect x="3" y="4" width="18" height="16" rx="2" /><path d="m7 9 3 3-3 3" /><path d="M13 15h4" />`,
  shield: `<path d="M12 3 4 6v6c0 4.5 3.2 8.5 8 9 4.8-.5 8-4.5 8-9V6z" />`,
  book: `<path d="M4 4h11a3 3 0 0 1 3 3v13" /><path d="M4 4v16h14" /><path d="M8 8h7M8 12h7" />`,
};
---

<section class="foundry-features" aria-label="Documentation sections">
  <h2 class="foundry-features__title">Find what you need</h2>
  <div class="foundry-features__grid">
    {
      features.map((feature) => (
        <a class="foundry-features__card" href={feature.href}>
          <span class="foundry-features__icon" aria-hidden="true">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons[feature.icon]}
            />
          </span>
          <h3 class="foundry-features__card-title">{feature.title}</h3>
          <p class="foundry-features__card-desc">{feature.description}</p>
          <span class="foundry-features__card-arrow" aria-hidden="true">→</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .foundry-features {
    margin: 4.5rem 0 2rem;
  }

  .foundry-features__title {
    margin: 0 0 2rem;
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--sl-color-white, var(--text-heading));
  }

  .foundry-features__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }

  .foundry-features__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 1.5rem 1.75rem;
    border-radius: var(--foundry-radius-lg);
    border: 1px solid var(--border-default);
    background: var(--surface-default);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.3s ease;
  }

  .foundry-features__card:hover {
    border-color: var(--card-hover-border);
  }

  .foundry-features__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--foundry-radius-md);
    background: var(--pill-bg);
    border: 1px solid var(--pill-border);
    color: var(--accent-default);
  }

  .foundry-features__card-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--sl-color-white, var(--text-heading));
  }

  .foundry-features__card-desc {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .foundry-features__card-arrow {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    font-size: 1rem;
    color: var(--accent-default);
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .foundry-features__card:hover .foundry-features__card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
