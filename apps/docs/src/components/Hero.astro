---
/**
 * Hero — Foundry docs home hero.
 *
 * Pure Astro component. No React imports. Uses tokens from
 * `foundry-tokens.css` and Starlight theme variables so it responds to
 * light/dark mode automatically.
 *
 * Design aligned with the Bespoke Agentics brand system: DM Sans
 * typography, pill badge, hero gradient backdrop, signal arc motif.
 *
 * Pairs with a copy-pasteable quickstart snippet and <FeatureGrid /> on
 * the home page. Starlight's native Hero is intentionally not used so
 * that the layout matches the Foundry brand rather than Starlight's
 * default `splash` template.
 */

import { Code } from "@astrojs/starlight/components";

interface Props {
  tagline?: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
}

const {
  tagline = "The open-source Agentic Delivery Platform. Turn plans, conversations, and requirements into shipping software.",
  primaryCta = { text: "Get started in 15 minutes", href: "/getting-started/quickstart/" },
  secondaryCta = { text: "View on GitHub", href: "https://github.com/qdhenry/Foundry-OSS" },
} = Astro.props;

const quickstartSnippet = `git clone https://github.com/qdhenry/Foundry-OSS.git
cd Foundry
bun install
cp .env.local.example .env.local   # fill in Clerk + Convex + Anthropic keys
bun run dev:convex                  # terminal 1
bun run dev                         # terminal 2`;
---

<section class="foundry-hero">
  <div class="foundry-hero__backdrop" aria-hidden="true"></div>
  <div class="foundry-hero__content">
    <span class="foundry-pill">
      <span class="foundry-pill__dot"></span>
      Open Source · Apache-2.0
    </span>
    <h1 class="foundry-hero__title">
      Ship software at the <span class="foundry-hero__accent">speed of thought</span>.
    </h1>
    <p class="foundry-hero__tagline">{tagline}</p>
    <div class="foundry-hero__actions">
      <a class="foundry-hero__cta foundry-hero__cta--primary" href={primaryCta.href}>
        {primaryCta.text}
        <span aria-hidden="true">&rarr;</span>
      </a>
      <a
        class="foundry-hero__cta foundry-hero__cta--secondary"
        href={secondaryCta.href}
        target={secondaryCta.href.startsWith("http") ? "_blank" : undefined}
        rel={secondaryCta.href.startsWith("http") ? "noopener noreferrer" : undefined}
      >
        {secondaryCta.text}
      </a>
    </div>
  </div>

  <div class="foundry-hero__snippet">
    <Code code={quickstartSnippet} lang="bash" title="Quickstart" />
  </div>
</section>

<style>
  .foundry-hero {
    position: relative;
    display: grid;
    gap: 3rem;
    padding: 5.5rem 0 4rem;
    border-bottom: 1px solid var(--border-subtle);
    overflow: hidden;
  }

  .foundry-hero__backdrop {
    position: absolute;
    inset: 0;
    background: var(--hero-gradient);
    pointer-events: none;
  }

  @media (min-width: 900px) {
    .foundry-hero {
      grid-template-columns: 1.1fr 1fr;
      align-items: center;
      gap: 3rem;
    }
  }

  .foundry-hero__content {
    position: relative;
    z-index: 1;
  }

  .foundry-hero__title {
    margin: 2.5rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--sl-color-white, var(--text-heading));
  }

  .foundry-hero__accent {
    color: var(--accent-default);
  }

  .foundry-hero__tagline {
    margin: 2rem 0 2.5rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    font-weight: 400;
    max-width: 42rem;
    color: var(--sl-color-gray-3, var(--text-secondary));
  }

  .foundry-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .foundry-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--foundry-radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .foundry-hero__cta--primary {
    background: var(--cta-primary-bg);
    color: var(--text-on-brand);
    border: 1px solid transparent;
  }

  .foundry-hero__cta--primary:hover {
    background: var(--cta-primary-hover);
    box-shadow: var(--shadow-button-hover);
    color: var(--text-on-brand);
  }

  .foundry-hero__cta--secondary {
    background: transparent;
    color: var(--sl-color-text, var(--text-primary));
    border: 1px solid var(--border-strong);
  }

  .foundry-hero__cta--secondary:hover {
    border-color: var(--accent-default);
    background: var(--interactive-active);
  }

  .foundry-hero__snippet {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  /* Starlight's <Code /> renders a framed panel; nudge it to feel like
     a terminal output in the hero without overriding token colors. */
  .foundry-hero__snippet :global(.expressive-code) {
    box-shadow: var(--shadow-lg);
    border-radius: var(--foundry-radius-lg);
    overflow: hidden;
  }
</style>
